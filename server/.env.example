# ===== Application =====
APP_ENV=development
APP_NAME=night-diary-v2

# ===== Data directory =====
# Override default (Windows: %APPDATA%/night-diary, macOS/Linux: ~/.local/share/night-diary)
# DATA_DIR=D:/my_data/night-diary

# ===== Port =====
# PORT=8000

# ===== Security =====
# Fernet key for encrypting LLM API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MODEL_KEY_SECRET=

# ===== LLM defaults (can be overridden per provider in-app) =====
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
