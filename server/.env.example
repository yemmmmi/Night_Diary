# ===== Application =====
APP_ENV=development
APP_NAME=night-diary-v2

# ===== Database =====
# Local dev (matches docker-compose.yml service "mysql"):
DATABASE_URL=mysql+pymysql://nightdiary:nightdiary@localhost:3306/nightdiary

# --- Cloud / production example (uncomment & adjust) ---
# Most managed MySQL providers require SSL. Provide the CA bundle path:
# DATABASE_URL=mysql+pymysql://USER:PASS@HOST:3306/DBNAME?ssl_ca=/etc/ssl/certs/ca.pem
# Some drivers/providers prefer query flags like ?ssl=true or
# `ssl_verify_cert=true&ssl_verify_identity=true`. Consult your provider.

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Security =====
# REQUIRED. App fails to start if missing or shorter than 16 chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please-change-me-use-a-random-32+-char-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# REQUIRED. Independent secret used to encrypt user-stored LLM API keys.
MODEL_KEY_SECRET=please-change-me-use-another-random-secret

# ===== CORS =====
# Comma-separated list. Use the deployed frontend origin(s) in production.
ALLOWED_ORIGINS=http://localhost:5173

# ===== Trusted proxies (rate limiter / distributed lock IP detection) =====
# Comma-separated. Leave empty for direct connections; populate when behind
# a load balancer / reverse proxy that you trust to set X-Forwarded-For.
TRUSTED_PROXY_IPS=

# ===== RAG / Knowledge =====
# Local Chroma persistence. Phase 5 deployment docs cover hosted alternatives.
CHROMA_PERSIST_DIR=./chroma_data
